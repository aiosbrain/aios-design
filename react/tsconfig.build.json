{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "allowImportingTsExtensions": false,
    "outDir": "dist",
    "rootDir": ".",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["index.ts", "components", "lib"],
  "exclude": ["src", "node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"]
}
