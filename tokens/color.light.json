    "border":         { "$value": "rgba(0, 0, 0, 0.10)",     "$type": "color" },
    "border-visible": { "$value": "rgba(0, 0, 0, 0.14)",     "$type": "color" },
    "border-strong":  { "$value": "rgba(0, 0, 0, 0.22)",     "$type": "color" },

    "primary":        { "$value": "#0a0a0a",                 "$type": "color" },
    "primary-hover":  { "$value": "#2a2a2a",                 "$type": "color" },
    "primary-fg":     { "$value": "#ffffff",                 "$type": "color" },

    "accent":         { "$value": "#84cc16",                 "$type": "color" },
    "accent-fg":      { "$value": "#0a0a0a",                 "$type": "color" },

    "emerald":        { "$value": "#10b981",                 "$type": "color" },
    "amber":          { "$value": "#f59e0b",                 "$type": "color" },
    "cyan":           { "$value": "#0d9488",                 "$type": "color" },
    "fuchsia":        { "$value": "#c026d3",                 "$type": "color" },

    "destructive":    { "$value": "#ef4444",                 "$type": "color" },
    "destructive-fg": { "$value": "#ffffff",                 "$type": "color" },

    "ring":           { "$value": "#1a1a1a",                 "$type": "color" },
    "code-bg":        { "$value": "#f4f4f5",                 "$type": "color" }
  },
  "shadow": {
    "button":  { "$value": "none",                          "$type": "shadow" },
    "card":    { "$value": "0 1px 2px rgba(0, 0, 0, 0.04)", "$type": "shadow" },
